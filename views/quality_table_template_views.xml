<odoo>
  <record id="view_quality_table_template_tree" model="ir.ui.view">
    <field name="name">coordos.quality.table.template.tree</field>
    <field name="model">coordos.quality.table.template</field>
    <field name="arch" type="xml">
      <tree string="质检表模板中心">
        <field name="active"/>
        <field name="sequence"/>
        <field name="name"/>
        <field name="code"/>
        <field name="target_table_type"/>
        <field name="min_score"/>
        <field name="current_version_no"/>
        <field name="last_version_at"/>
      </tree>
    </field>
  </record>

  <record id="view_quality_table_template_form" model="ir.ui.view">
    <field name="name">coordos.quality.table.template.form</field>
    <field name="model">coordos.quality.table.template</field>
    <field name="arch" type="xml">
      <form string="质检表模板中心">
        <header>
          <button name="action_create_manual_snapshot" type="object" string="手动生成版本" class="btn-secondary"/>
          <button name="action_open_import_wizard" type="object" string="批量导入模板" class="btn-primary"/>
        </header>
        <sheet>
          <group>
            <field name="active"/>
            <field name="sequence"/>
            <field name="name"/>
            <field name="code"/>
            <field name="target_table_type"/>
            <field name="min_score"/>
            <field name="title_regex"/>
            <field name="current_version_no" readonly="1"/>
            <field name="last_version_at" readonly="1"/>
          </group>
          <group string="匹配规则">
            <field name="required_keywords" placeholder="每行一个必含关键词"/>
            <field name="keyword_rules" placeholder="每行一个命中规则，支持 A|B 和 file: 前缀"/>
          </group>
          <group string="字段提取">
            <field name="field_patterns_json" nolabel="1"/>
          </group>
          <group string="默认值">
            <field name="default_values_json" nolabel="1"/>
          </group>
          <group string="备注">
            <field name="notes" nolabel="1"/>
          </group>
          <notebook>
            <page string="版本历史">
              <field name="version_ids" nolabel="1" readonly="1">
                <tree create="0" edit="0" delete="0">
                  <field name="version_no"/>
                  <field name="is_current"/>
                  <field name="note"/>
                  <field name="create_uid"/>
                  <field name="create_date"/>
                  <button name="action_restore_version" type="object" string="恢复此版本"/>
                </tree>
                <form string="模板版本">
                  <header>
                    <button name="action_restore_version" type="object" string="恢复此版本" class="btn-primary"/>
                  </header>
                  <sheet>
                    <group>
                      <field name="template_id" readonly="1"/>
                      <field name="template_code" readonly="1"/>
                      <field name="version_no" readonly="1"/>
                      <field name="is_current" readonly="1"/>
                      <field name="note"/>
                      <field name="create_uid" readonly="1"/>
                      <field name="create_date" readonly="1"/>
                    </group>
                    <group string="版本内容">
                      <field name="data_json" nolabel="1" readonly="1"/>
                    </group>
                  </sheet>
                </form>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_quality_table_template_version_tree" model="ir.ui.view">
    <field name="name">coordos.quality.table.template.version.tree</field>
    <field name="model">coordos.quality.table.template.version</field>
    <field name="arch" type="xml">
      <tree string="模板版本列表" create="0" edit="0">
        <field name="template_id"/>
        <field name="template_code"/>
        <field name="version_no"/>
        <field name="is_current"/>
        <field name="note"/>
        <field name="create_uid"/>
        <field name="create_date"/>
      </tree>
    </field>
  </record>

  <record id="view_quality_table_template_import_wizard_form" model="ir.ui.view">
    <field name="name">quality.table.template.import.wizard.form</field>
    <field name="model">quality.table.template.import.wizard</field>
    <field name="arch" type="xml">
      <form string="模板批量导入">
        <sheet>
          <group string="导入参数">
            <field name="file" filename="file_name"/>
            <field name="file_name"/>
            <field name="source_format"/>
            <field name="import_mode"/>
            <field name="dry_run"/>
            <field name="version_note"/>
          </group>
          <group string="执行结果">
            <field name="total_rows" readonly="1"/>
            <field name="created_count" readonly="1"/>
            <field name="updated_count" readonly="1"/>
            <field name="skipped_count" readonly="1"/>
            <field name="error_count" readonly="1"/>
            <field name="result_text" readonly="1"/>
          </group>
        </sheet>
        <footer>
          <button name="action_import" type="object" string="执行导入" class="btn-primary"/>
          <button string="关闭" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_quality_table_template" model="ir.actions.act_window">
    <field name="name">质检表模板中心</field>
    <field name="res_model">coordos.quality.table.template</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_quality_table_template_import_wizard" model="ir.actions.act_window">
    <field name="name">模板批量导入</field>
    <field name="res_model">quality.table.template.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>

  <menuitem id="menu_quality_table_template"
            name="质检表模板中心"
            parent="menu_coordos_config_root"
            action="action_quality_table_template"
            sequence="35"
            groups="coordos_odoo.group_coordos_company_admin"/>

  <menuitem id="menu_quality_table_template_import"
            name="模板批量导入"
            parent="menu_coordos_config_root"
            action="action_quality_table_template_import_wizard"
            sequence="36"
            groups="coordos_odoo.group_coordos_company_admin"/>
</odoo>
